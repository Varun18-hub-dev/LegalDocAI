# LegalDocAI Environment Configurations
APP_ENV=production
DATA_DIR=/data

# Google Gemini API Key
GEMINI_API_KEY=

# Security & Tokens
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial Admin Seeding (Configured only via environment)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=LegalDocAI Admin

# Production CORS URL Constraints
FRONTEND_URL=
CORS_ORIGINS=

# Dynamic Paths (Must resolve under DATA_DIR volume mount in production)
SQLITE_DB_PATH=/data/sqlite/legaldocai.db
CHROMA_DB_PATH=/data/chroma
UPLOAD_DIR=/data/uploads
LOG_DIR=/data/logs
